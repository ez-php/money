{
  "name": "ez-php/money",
  "version": "1.5.0",
  "description": "Immutable Money and Currency value objects for the ez-php ecosystem — ISO 4217 currencies, arbitrary-precision arithmetic via ez-php/bignum, allocation, and locale-aware formatting",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["money", "currency", "iso4217", "bigdecimal", "financial", "php", "ez-php"],
  "homepage": "https://github.com/ez-php/money",
  "support": {
    "issues": "https://github.com/ez-php/money/issues",
    "source": "https://github.com/ez-php/money"
  },
  "require": {
    "php": "^8.5",
    "ext-gmp": "*",
    "ez-php/bignum": "^1.0"
  },
  "suggest": {
    "ext-intl": "Required for IntlMoneyFormatter and IntlMoneyParser (locale-aware formatting)"
  },
  "require-dev": {
    "ez-php/docker": "^1.0",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Money\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
